{
  "name": "steam-pc-local-image-browser",
  "version": "0.1.0",
  "private": true,
  "description": "Steam 本地图片浏览器 — 浏览、收藏、拼图 Steam 游戏图片",
  "author": "linmingqi",
  "type": "module",
  "main": "dist-electron/electron/main.js",
  "scripts": {
    "dev": "vite --host 127.0.0.1 --port 5173 --strictPort",
    "build:electron": "tsc -p tsconfig.node.json",
    "dev:electron": "concurrently -k \"npm run dev\" \"npm run build:electron && wait-on tcp:5173 && cross-env VITE_DEV_SERVER_URL=http://127.0.0.1:5173 electron .\"",
    "build": "vue-tsc --noEmit && vite build && tsc -p tsconfig.node.json",
    "dist": "npm run build && electron-builder",
    "test": "vitest run",
    "typecheck": "vue-tsc --noEmit && tsc -p tsconfig.node.json --noEmit"
  },
  "build": {
    "appId": "com.steampc.imagebrowser",
    "productName": "SteamImageBrowser",
    "icon": "build/icon.svg",
    "directories": {
      "output": "release"
    },
    "files": [
      "dist/**",
      "dist-electron/**",
      "package.json"
    ],
    "electronDist": "node_modules/electron/dist",
    "win": {
      "target": "nsis"
    },
    "nsis": {
      "oneClick": false,
      "perMachine": false,
      "allowToChangeInstallationDirectory": true,
      "artifactName": "SteamImageBrowser-Setup-${version}.exe"
    }
  },
  "dependencies": {
    "vue": "latest"
  },
  "devDependencies": {
    "@vitejs/plugin-vue": "latest",
    "@types/node": "latest",
    "@unocss/preset-uno": "^66.7.4",
    "@vue/tsconfig": "latest",
    "concurrently": "latest",
    "cross-env": "latest",
    "electron": "latest",
    "electron-builder": "latest",
    "typescript": "latest",
    "unocss": "^66.7.4",
    "vite": "latest",
    "vitest": "latest",
    "vue-tsc": "latest",
    "wait-on": "latest"
  }
}
